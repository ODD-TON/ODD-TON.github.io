---
import { SITE_GITHUB_URL, SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="brand">
			<a href="/">{SITE_TITLE}</a>
			<span>Personal site</span>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<a class="github-link" href={SITE_GITHUB_URL} target="_blank" rel="noreferrer">GitHub</a>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 1.25rem;
		backdrop-filter: blur(14px);
		background: rgba(255, 252, 247, 0.82);
		border-bottom: 1px solid rgba(var(--gray), 0.18);
	}
	h2 {
		margin: 0;
		font-size: 1rem;
	}
	.brand {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
	}
	.brand span {
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 76px;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}
	nav a {
		padding: 0.75rem 0.7rem;
		color: var(--black);
		text-decoration: none;
	}
	nav a.active {
		color: var(--accent);
	}
	.github-link {
		border: 1px solid rgba(var(--gray-dark), 0.18);
		border-radius: 999px;
		font-size: 0.95rem;
		font-weight: 600;
		background: rgba(255, 255, 255, 0.7);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}
		nav {
			min-height: 68px;
		}
		.brand span,
		.github-link {
			display: none;
		}
		.internal-links {
			margin-left: auto;
		}
	}
</style>
