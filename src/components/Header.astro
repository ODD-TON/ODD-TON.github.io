---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="brand"><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		margin: 0;
		padding: 0 1.25rem;
		backdrop-filter: blur(14px);
		background: rgba(255, 252, 247, 0.86);
		border-bottom: 1px solid rgba(var(--gray), 0.16);
	}

	h2 {
		margin: 0;
		font-size: 1.05rem;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		min-height: 72px;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.35rem;
	}

	@media (max-width: 720px) {
		header {
			padding: 0 1rem;
		}

		nav {
			min-height: 64px;
		}
	}
</style>
