---
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label="返回首页">
			<img src="/favicon/favicon.png" alt="" width="32" height="32" />
		</a>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		padding: 0.85rem 1.25rem 0;
	}

	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		width: min(var(--content-width), calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.65rem 0.8rem;
		border-radius: 999px;
		background: rgba(255, 251, 246, 0.8);
		border: 1px solid var(--line);
		backdrop-filter: blur(18px);
		box-shadow: 0 10px 30px rgba(98, 79, 61, 0.08);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 42px;
		height: 42px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.72);
		border: 1px solid rgba(178, 145, 110, 0.18);
		box-shadow: 0 8px 20px rgba(98, 79, 61, 0.08);
	}

	.brand img {
		display: block;
		width: 28px;
		height: 28px;
		border-radius: 8px;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	@media (max-width: 720px) {
		header {
			padding: 0.7rem 0.6rem 0;
		}

		nav {
			width: calc(100% - 0.5rem);
			padding: 0.55rem 0.6rem;
			border-radius: 24px;
		}

		.brand {
			width: 38px;
			height: 38px;
		}

		.brand img {
			width: 24px;
			height: 24px;
		}

		.internal-links {
			gap: 0.05rem;
		}
	}
</style>
