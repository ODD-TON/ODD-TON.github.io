---
import { SITE_AUTHOR, SITE_GITHUB_URL, SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	<p class="meta">
		&copy; {today.getFullYear()} {SITE_AUTHOR}. 这个站点由 Astro 构建，并通过 GitHub Pages 发布。
	</p>
	<div class="footer-links">
		<a href="/">返回首页</a>
		<a href="/blog">查看博客</a>
		<a href={SITE_GITHUB_URL} target="_blank" rel="noreferrer">仓库地址</a>
	</div>
	<p class="signature">{SITE_TITLE} is under active construction.</p>
</footer>
<style>
	footer {
		padding: 3rem 1rem 4rem;
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.8), transparent 56%),
			linear-gradient(180deg, rgba(var(--gray-light), 0.18), rgba(255, 247, 237, 0.9));
		color: rgb(var(--gray));
		text-align: center;
	}
	.meta,
	.signature {
		margin: 0;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 1rem;
		margin: 1rem 0 0.75rem;
	}
	.footer-links a {
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 600;
	}
</style>
