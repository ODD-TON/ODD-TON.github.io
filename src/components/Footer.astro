---
import { SITE_AUTHOR, SOCIAL_LINKS } from '../consts';

const today = new Date();
---

<footer>
	<div class="social-links" aria-label="联系方式">
		{
			SOCIAL_LINKS.map((item) => (
				<a href={item.href} aria-label={item.label} title={item.label}>
					{
						item.icon === 'mail' ? (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
								<path
									fill="currentColor"
									d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25zm2.1-.25L12 11.325 18.9 6.5zM19.5 7.965l-7.07 4.949a.75.75 0 0 1-.86 0L4.5 7.965v9.285c0 .69.56 1.25 1.25 1.25h12.5c.69 0 1.25-.56 1.25-1.25z"
								></path>
							</svg>
						) : (
							<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
								<path
									fill="currentColor"
									d="M6.18 15.64A6.97 6.97 0 0 1 5 11.75 7 7 0 0 1 12 4.75a7 7 0 0 1 6.82 8.57l2.03.62A9.12 9.12 0 0 0 21 11.75 9 9 0 0 0 3 11.75c0 1.9.58 3.67 1.57 5.14zM13 13v7.25a.75.75 0 0 1-1.5 0V13zm0-8.2a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"
								></path>
							</svg>
						)
					}
				</a>
			))
		}
	</div>
	<p class="meta">&copy; {today.getFullYear()} {SITE_AUTHOR}</p>
</footer>
<style>
	footer {
		padding: 2.75rem 1rem 3rem;
		text-align: center;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		border-radius: 999px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(var(--gray-dark), 0.08);
		box-shadow: var(--box-shadow);
	}

	.social-links a:hover {
		color: var(--accent);
	}

	.meta {
		margin: 0;
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}
</style>
