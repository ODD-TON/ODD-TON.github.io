---
import { Image } from 'astro:assets';
import HomeIllustration from '../assets/site/mt.png';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_BIO, SITE_DESCRIPTION, SITE_INTRO, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-card">
				<div class="intro">
					<p class="eyebrow">欢迎来到小Ton的主页</p>
					<h1>{SITE_TITLE}</h1>
					<p class="bio">{SITE_BIO}</p>
					<p>{SITE_INTRO}</p>
					<p class="note">希望这里能留住一些当下的心情 也让每次回来看时 都还能想起那一刻的光线和温度</p>
				</div>
				<div class="artwork">
					<Image
						src={HomeIllustration}
						width={720}
						height={540}
						alt="一只在餐厅柜台后端着汉堡和饮料的狼角色插图"
					/>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		display: flex;
		align-items: center;
		padding-top: 1.25rem;
		padding-bottom: 0.5rem;
	}

	.home-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(280px, 460px);
		gap: 2rem;
		align-items: center;
		width: 100%;
		padding: 1.25rem;
		border-radius: 30px;
		background: rgba(255, 255, 255, 0.78);
		border: 1px solid rgba(var(--gray-dark), 0.08);
		box-shadow: var(--box-shadow);
	}

	.eyebrow {
		margin: 0 0 0.8rem;
		font-size: 0.84rem;
		font-weight: 700;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--accent);
	}

	.bio {
		margin-bottom: 0.35rem;
		font-size: 1.15rem;
		font-weight: 700;
		color: rgb(var(--black));
	}

	.note {
		margin-bottom: 0;
		color: rgba(var(--gray-dark), 0.82);
	}

	.artwork img {
		width: 100%;
		box-shadow: var(--box-shadow);
	}

	@media (max-width: 900px) {
		main {
			align-items: stretch;
		}

		.home-card {
			grid-template-columns: 1fr;
		}
	}
</style>
