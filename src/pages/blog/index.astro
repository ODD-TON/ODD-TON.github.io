---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${SITE_TITLE} | 博客`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<h1>博客</h1>
				<p>这里会慢慢放上所有文章。页面保持简单，只按时间顺序整理内容。</p>
			</section>
			<section>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<h2>{post.data.title}</h2>
									<p>{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		max-width: 38rem;
		margin-bottom: 1.5rem;
	}

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 1rem;
	}

	.post-list li a {
		display: block;
		padding: 1.2rem 1.25rem;
		text-decoration: none;
		border-radius: 24px;
		background: rgba(255, 255, 255, 0.82);
		border: 1px solid rgba(var(--gray-dark), 0.08);
		box-shadow: var(--box-shadow);
	}

	.post-list h2 {
		margin-bottom: 0.35rem;
		font-size: 1.55rem;
	}

	.post-list p {
		margin: 0;
		color: rgb(var(--gray-dark));
	}

	.post-list .date {
		margin-bottom: 0.55rem;
		font-size: 0.92rem;
		color: rgb(var(--gray));
	}

	.post-list li a:hover h2 {
		color: var(--accent);
	}
</style>
