---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`关于 ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<p class="eyebrow">About</p>
				<h1>关于</h1>
				<p>
					这是一个只用来放文章的简单博客。首页保留最基本的介绍，博客页负责归档文章，关于页用来说明内容和目录结构。
				</p>
			</section>

			<section class="grid">
				<article>
					<h2>写作方式</h2>
					<p>每篇文章都用 Markdown 写在仓库里，发布后会自动更新到站点。</p>
				</article>
				<article>
					<h2>内容范围</h2>
					<p>这里只放正式文章，不再额外扩展项目页或其它展示内容。</p>
				</article>
				<article>
					<h2>图片附件</h2>
					<p>文章里引用的图片或附件统一按文章 slug 分文件夹存放，后面维护会更清晰。</p>
				</article>
			</section>

			<section class="structure">
				<h2>文件结构</h2>
				<ul>
					<li><code>src/content/blog/</code>：存放所有博客文章。</li>
					<li><code>public/blog-media/&lt;slug&gt;/</code>：存放对应文章的图片和附件。</li>
					<li><code>src/assets/site/</code>：存放首页或站点公用图片。</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.intro {
		max-width: 42rem;
		margin-bottom: 1.8rem;
	}

	.eyebrow {
		display: inline-flex;
		align-items: center;
		margin: 0 0 0.8rem;
		padding: 0.34rem 0.66rem;
		border-radius: 999px;
		background: rgba(178, 145, 110, 0.12);
		font-size: 0.8rem;
		font-weight: 700;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		color: var(--accent-dark);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
		margin-bottom: 1rem;
	}

	article,
	.structure {
		padding: 1.35rem;
		border-radius: 26px;
		background: var(--surface-strong);
		border: 1px solid var(--line);
		box-shadow: var(--box-shadow);
	}

	article:nth-child(2) {
		transform: translateY(0.35rem);
	}

	.structure {
		margin-top: 0.6rem;
	}

	.structure ul {
		margin: 0;
		padding-left: 1.25rem;
	}

	.structure li + li {
		margin-top: 0.6rem;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr;
		}

		article:nth-child(2) {
			transform: none;
		}
	}
</style>
